# --- Production compose config ---
DB_NAME=ai_interview_ds
DB_USERNAME=interwise_app
DB_PASSWORD=replace_with_a_long_random_database_password
MYSQL_ROOT_PASSWORD=replace_with_a_different_long_random_root_password

# At least 32 characters. Use a strong random value.
JWT_SIGN_KEY=replace_with_a_long_random_jwt_signing_key_32_chars_min
JWT_EXPIRE_MS=86400000

# Admin analytics, rate limiting and daily AI quota protection.
APP_ADMIN_TOKEN=replace_with_a_strong_admin_analytics_token
APP_ANALYTICS_HASH_SALT=replace_with_a_long_random_analytics_hash_salt
APP_RATE_LIMIT_ENABLED=true
APP_QUOTA_ENABLED=true
APP_DAILY_INTERVIEW_LIMIT=5
APP_DAILY_AI_CHAT_TURN_LIMIT=80
APP_DAILY_RESUME_PARSE_LIMIT=3
APP_DAILY_MENTOR_GENERATE_LIMIT=3
# Developer whitelist. Comma-separated. Never put account passwords here.
APP_DEVELOPER_EXEMPT_USER_IDS=
APP_DEVELOPER_EXEMPT_USERNAMES=
APP_DEVELOPER_EXEMPT_EMAILS=

# DeepSeek API key. Required for interview and report generation.
DEEPSEEK_API_KEY=replace_with_your_deepseek_api_key

# Question bank / RAG / standalone MCP. Required for the full production feature set.
QDRANT_ENABLED=true
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=interview_atoms
QDRANT_VECTOR_SIZE=384
QUESTION_BANK_ADMIN_TOKEN=replace_with_a_strong_question_bank_admin_token
# Browser-origin allowlist for the standalone MCP service. CLI clients usually send no Origin.
MCP_ALLOWED_ORIGINS=http://replace_with_server_public_ip
APP_MCP_PUBLIC_URL=http://replace_with_server_public_ip/mcp
MCP_PUBLIC_MAX_LIMIT=5
MCP_MAX_QUERY_LENGTH=1000
# 每日调用额度以 mcp_quota_policy 表为准；如需调整，请更新该表。
QUESTION_BANK_SEED_FROM_JSON=true
QUESTION_BANK_REINDEX_ON_STARTUP=true
QUESTION_BANK_LEGACY_LOADER_ENABLED=false

# Mail config. Required for registration and password reset email flows.
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=replace_with_your_email
MAIL_PASSWORD=replace_with_your_smtp_authorization_code

# No domain yet: set this to the Azure VM public IP origin used by testers.
# Example: http://52.140.216.52
APP_CORS_ALLOWED_ORIGINS=http://replace_with_server_public_ip

# Optional HTTPS reverse proxy. Leave FRONTEND_HTTP_BIND as 80 for IP-only HTTP.
# When enabling the https profile, set:
# DOMAIN_NAME=your-dns-name
# FRONTEND_HTTP_BIND=127.0.0.1:8080
DOMAIN_NAME=
FRONTEND_HTTP_BIND=80
