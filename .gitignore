# ========== 通用IDE忽略规则 ==========
# IntelliJ IDEA
/out/
!**/src/main/**/out/
!**/src/test/**/out/
.idea/
*.iml
.kotlin

# Eclipse
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache
/bin/
!**/src/main/**/bin/
!**/src/test/**/bin/

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# VS Code
.vscode/

# ========== 系统/环境忽略 ==========
# Mac OS
.DS_Store

# Windows
Thumbs.db
*.tmp

# ========== JavaEE 项目核心忽略 ==========
# 编译产物（优先级最高，避免重复）
/target/
*.class
*.war
*.ear
# 注意：删除了全局的 *.jar 规则，避免覆盖 WEB-INF/lib 的例外

# 依赖包（只忽略根目录lib，保留WEB-INF/lib）
/lib/
!**/WEB-INF/lib/
# 补充：只忽略 WEB-INF/lib 之外的 jar 文件
!**/WEB-INF/lib/*.jar
*.jar

# 日志文件
*.log
/logs/
/temp/

# 敏感配置文件（不上传）
application.properties
application.yml
application-dev.yml
application-prod.yml

# 配置模板（保留，方便协作）
!application-template.properties
!application-template.yml