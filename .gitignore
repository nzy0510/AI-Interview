# ========== 通用IDE忽略规则 ==========
# IntelliJ IDEA
/out/
!**/src/main/**/out/
!**/src/test/**/out/
.idea/
**/.idea/
*.iml
.kotlin

# Eclipse
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache
/bin/
!**/src/main/**/bin/
!**/src/test/**/bin/

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# VS Code
.vscode/

# ========== 系统/环境忽略 ==========
# Mac OS
.DS_Store

# Windows
Thumbs.db
*.tmp

# ========== 环境变量与敏感配置 (重要：绝不提交) ==========
.env
.env.*
!.env.example
!.env.prod.example
docker-compose.yml
!docker-compose.example.yml
**/application.yml
!**/application.yml.example
!backend/src/main/resources/application.yml

# ========== JavaEE 项目核心忽略 ==========
# 编译产物
**/target/
*.class
*.war
*.ear
*.jar
!**/WEB-INF/lib/*.jar

# 依赖包
/lib/
!**/WEB-INF/lib/
node_modules/
__pycache__/
**/__pycache__/

# 构建输出
dist/
build_err.txt

# 日志文件
*.log
/logs/
/temp/

# 敏感配置文件（不上传）
application.properties
application-dev.yml
application-prod.yml

# 配置模板（保留，方便协作）
!application-template.properties

# ========== 数据库与持久化数据 (重要：绝不提交) ==========
