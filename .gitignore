# ========== 通用IDE忽略规则 ==========
# IntelliJ IDEA
/out/
!**/src/main/**/out/
!**/src/test/**/out/
.idea/
**/.idea/
*.iml
.kotlin

# Eclipse
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache
/bin/
!**/src/main/**/bin/
!**/src/test/**/bin/

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# VS Code
.vscode/

# ========== 系统/环境忽略 ==========
# Mac OS
.DS_Store

# Windows
Thumbs.db
*.tmp

# ========== 环境变量与敏感配置 (重要：绝不提交) ==========
.env
!.env.example
docker-compose.yml
!docker-compose.example.yml
**/application.yml
!**/application.yml.example

# ========== JavaEE 项目核心忽略 ==========
# 编译产物
**/target/
*.class
*.war
*.ear
*.jar
!**/WEB-INF/lib/*.jar

# 依赖包
/lib/
!**/WEB-INF/lib/
node_modules/

# 构建输出
dist/
build_err.txt

# 日志文件
*.log
/logs/
/temp/

# 敏感配置文件（不上传）
application.properties
application-dev.yml
application-prod.yml

# 配置模板（保留，方便协作）
!application-template.properties

# ========== 数据库与持久化数据 (重要：绝不提交) ==========
/mysql_data/
/redis_data/
/document/

# ========== 临时/测试文件 ==========
测试简历.pdf
docker使用说明.txt
branches.txt
conflicts.txt
conflicts_render.txt

# ========== Claude Code 本地配置 ==========
.claude/

# ========== 知识库相关 ==========
# 忽略原始大型文档，保留生成的 JSON 原子
*.pdf
**/knowledge_base/archive_original/

变量.txt

# ========== Claude Code & Docs ==========
CLAUDE.md
/docs/
