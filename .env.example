# --- 数据库配置 ---
DB_NAME=ai_interview_ds
DB_USERNAME=nzy333
DB_PASSWORD=your_password_here
MYSQL_ROOT_PASSWORD=root

# --- AI 模型配置 (必须填写，否则面试功能无法使用) ---
# 申请地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# --- JWT 签名密钥 (必须填写，至少 32 字符，生产环境使用强随机密钥) ---
JWT_SIGN_KEY=your_jwt_signing_key_at_least_32_characters

# --- 题库维护 / MCP / Qdrant ---
# 开发者维护题库用，生产建议设置为强随机值
QUESTION_BANK_ADMIN_TOKEN=change_me_question_bank_admin_token
# 外部 AI 客户端只读 MCP token，生产建议设置为强随机值
MCP_READ_TOKEN=change_me_mcp_read_token
# 浏览器来源白名单，逗号分隔；CLI/服务端 MCP 客户端通常不会带 Origin
MCP_ALLOWED_ORIGINS=
QDRANT_ENABLED=true
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=interview_atoms
QDRANT_VECTOR_SIZE=384
QUESTION_BANK_SEED_FROM_JSON=true
QUESTION_BANK_REINDEX_ON_STARTUP=true
QUESTION_BANK_LEGACY_LOADER_ENABLED=false

# --- 邮件服务配置 (必须填写，否则注册/忘记密码功能无法使用) ---
# QQ邮箱: 登录 mail.qq.com → 设置 → 账户 → 开启 POP3/SMTP 服务 → 获取授权码
# 163邮箱: MAIL_HOST=smtp.163.com，其余类似
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=your_email@qq.com
MAIL_PASSWORD=your_smtp_authorization_code

# --- 前端配置 ---
VITE_API_BASE_URL=http://localhost:8080
