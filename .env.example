# --- 数据库配置 (Docker 内部使用默认即可) ---
DB_HOST=db
DB_NAME=ai_interview_ds
DB_USERNAME=root
DB_PASSWORD=your_password_here

# --- AI 模型配置 (必须填写，否则面试功能无法使用) ---
# 申请地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# --- 邮件服务配置 (必须填写，否则注册/忘记密码功能无法使用) ---
# QQ邮箱: 登录 mail.qq.com → 设置 → 账户 → 开启 POP3/SMTP 服务 → 获取授权码
# 163邮箱: MAIL_HOST=smtp.163.com，其余类似
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=your_email@qq.com
MAIL_PASSWORD=your_smtp_authorization_code 

# --- 前端配置 ---
VITE_API_BASE_URL=http://localhost:8080
